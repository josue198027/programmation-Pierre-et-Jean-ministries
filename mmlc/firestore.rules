rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lecture publique (les fidèles consultent les programmes),
    // écriture réservée aux administrateurs connectés
    match /programmes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /membres/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
